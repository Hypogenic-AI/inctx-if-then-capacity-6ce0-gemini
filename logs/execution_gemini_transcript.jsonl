{"type":"tool_use","timestamp":"2026-03-16T05:35:19.437Z","tool_name":"write_file","tool_id":"write_file_1773639319437_0","parameters":{"content":"\nimport os\nimport json\nimport re\nfrom openai import OpenAI\nfrom tqdm import tqdm\nfrom taxonomy import TAXONOMY\n\nclient = OpenAI(api_key=os.environ.get(\"OPENAI_API_KEY\"))\n\ndef verify_content_llm(context, action_desc, response_segment):\n    \"\"\"Uses LLM to verify if a content action was performed.\"\"\"\n    prompt = f\"Rule: {action_desc}\\nResponse segment: {response_segment}\\nDid the response segment follow the rule? Respond ONLY with YES or NO.\"\n    try:\n        response = client.chat.completions.create(\n            model=\"gpt-4o-mini\",\n            messages=[{\"role\": \"user\", \"content\": prompt}],\n            temperature=0.0\n        )\n        return \"YES\" in response.choices[0].message.content.upper()\n    except:\n        return False\n\ndef identify_conceptual_triggers(response, concept):\n    \"\"\"Uses LLM to identify sentences that relate to the concept.\"\"\"\n    # This is a bit expensive, let's just identify IF the concept exists and then check the whole response\n    # Or more precisely, find where it exists.\n    prompt = f\"Concept: {concept}\\nResponse: {response}\\nList every sentence in the response that refers to the concept of '{concept}'. Return as a JSON list of strings. If none, return [].\"\n    try:\n        response = client.chat.completions.create(\n            model=\"gpt-4o-mini\",\n            messages=[{\"role\": \"user\", \"content\": prompt}],\n            temperature=0.0,\n            response_format={\"type\": \"json_object\"}\n        )\n        data = json.loads(response.choices[0].message.content)\n        # Search for the key \"sentences\" or similar\n        key = list(data.keys())[0]\n        return data[key]\n    except:\n        return []\n\ndef evaluate_results(results_path, output_path):\n    with open(results_path, \"r\") as f:\n        results = json.load(f)\n        \n    eval_results = []\n    print(f\"Evaluating {len(results)} responses from {results_path}...\")\n    for item in tqdm(results):\n        response = item[\"response\"]\n        if not response:\n            continue\n            \n        rule_evals = []\n        for rule in item[\"rules\"]:\n            tt = rule[\"trigger_type\"]\n            at = rule[\"action_type\"]\n            trigger = rule[\"trigger\"]\n            action = rule[\"action\"]\n            \n            # 1. Identify Triggers\n            trigger_instances = []\n            if tt == \"lexical\":\n                # Find all occurrences of the word\n                # Use word boundaries\n                pattern = re.compile(r'\\b' + re.escape(trigger) + r'\\b', re.IGNORECASE)\n                for m in pattern.finditer(response):\n                    # Get surrounding context (sentence)\n                    start = max(0, response.rfind('.', 0, m.start()) + 1)\n                    end = response.find('.', m.end())\n                    if end == -1: end = len(response)\n                    trigger_instances.append(response[start:end+1].strip())\n            elif tt == \"structural\":\n                if trigger == \"start of a paragraph\":\n                    paragraphs = [p.strip() for p in response.split('\\n\\n') if p.strip()]\n                    trigger_instances = [p[:100] for p in paragraphs] # Use start of paragraph\n                elif trigger == \"finish a sentence\":\n                     trigger_instances = [s.strip() for s in re.split(r'[.!?]', response) if s.strip()]\n                elif trigger == \"mention any number\":\n                     # Simplified check\n                     for m in re.finditer(r'\\d+', response):\n                         start = max(0, response.rfind('.', 0, m.start()) + 1)\n                         end = response.find('.', m.end())\n                         if end == -1: end = len(response)\n                         trigger_instances.append(response[start:end+1].strip())\n            elif tt == \"conceptual\":\n                trigger_instances = identify_conceptual_triggers(response, trigger)\n                \n            # 2. Verify Actions for each instance\n            rule_score = 0\n            if not trigger_instances:\n                # If trigger didn't happen, we can't measure adherence\n                # But wait, did the model perform the action anyway? (False Positives)\n                # Let's just mark it as N/A for now\n                rule_score = None \n            else:\n                passed = 0\n                for inst in trigger_instances:\n                    # Look at the sentence following the trigger or the trigger sentence itself\n                    # Find inst in response\n                    idx = response.find(inst)\n                    if idx == -1: continue # Should not happen\n                    \n                    next_part = response[idx + len(inst):idx + len(inst) + 200]\n                    target_sentence = inst # For formatting, usually the sentence itself\n                    \n                    is_correct = False\n                    if at == \"lexical\":\n                        if re.search(re.escape(action), next_part, re.IGNORECASE):\n                            is_correct = True\n                    elif at == \"formatting\":\n                        if action == \"BOLD\":\n                            if \"**\" in inst or \"__\" in inst: is_correct = True\n                        elif action == \"italics\":\n                            if \"*\" in inst or \"_\" in inst: is_correct = True\n                        elif action == \"UPPERCASE\":\n                            # Check if a substantial part is uppercase\n                            words = re.findall(r'\\w+', inst)\n                            if words and all(w.isupper() for w in words if len(w) > 3):\n                                is_correct = True\n                    elif at == \"content\":\n                        # Verify the next sentence\n                        is_correct = verify_content_llm(inst, action, next_part)\n                        \n                    if is_correct:\n                        passed += 1\n                \n                rule_score = passed / len(trigger_instances)\n                \n            rule_evals.append({\n                \"rule\": rule[\"instruction\"],\n                \"trigger_type\": tt,\n                \"action_type\": at,\n                \"score\": rule_score,\n                \"num_triggers\": len(trigger_instances)\n            })\n            \n        eval_results.append({\n            \"id\": item[\"id\"],\n            \"model\": item[\"model\"],\n            \"rule_evals\": rule_evals\n        })\n        \n    with open(output_path, \"w\") as f:\n        json.dump(eval_results, f, indent=2)\n\nif __name__ == \"__main__\":\n    evaluate_results(\"results/gpt-4o_results.json\", \"results/gpt-4o_eval.json\")\n    evaluate_results(\"results/gpt-4o-mini_results.json\", \"results/gpt-4o-mini_eval.json\")\n","file_path":"src/evaluator.py"}}
